{
  "name": "iobroker.xterm",
  "version": "3.1.0",
  "description": "This adapter allows to execute shell commands on ioBroker host.",
  "author": {
    "name": "ioBroker",
    "email": "dogafox@gmail.com"
  },
  "homepage": "https://github.com/ioBroker/ioBroker.xterm",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "terminal",
    "ssh"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ioBroker/ioBroker.xterm"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "@iobroker/webserver": "^1.4.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.19",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3"
  },
  "main": "build/main.js",
  "files": [
    "admin/",
    "public/",
    "build/",
    "LICENSE",
    "io-package.json"
  ],
  "scripts": {
    "build:tsc": "tsc -p tsconfig.build.json",
    "build": "npm run build:tsc && cd src-web && npm install && npm run build",
    "prepublishOnly": "npm run build",
    "test:package": "mocha test/package --exit",
    "test:unit": "mocha test/unit --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:package",
    "lint": "eslint -c eslint.config.mjs",
    "release": "release-script",
    "release-patch": "release-script patch --yes",
    "release-minor": "release-script minor --yes",
    "release-major": "release-script major --yes",
    "update-packages": "npx -y npm-check-updates --upgrade",
    "translate": "translate-adapter"
  },
  "bugs": {
    "url": "https://github.com/ioBroker/ioBroker.xterm/issues"
  },
  "readmeFilename": "README.md"
}
